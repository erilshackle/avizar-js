{
  "name": "avizar-js",
  "version": "1.0.0",
  "type": "module",
  "description": "Lightweight glassmorphism notification library with auto-injected styles.",
  "author": "Erilando Carvalho",
  "license": "MIT",
  "main": "./dist/avizar.min.js",
  "module": "./dist/avizar.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/avizar.esm.js",
      "require": "./dist/avizar.min.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "~5.4.0",
    "vite": "^5.0.0",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vite-plugin-dts": "^3.9.1"
  }
}